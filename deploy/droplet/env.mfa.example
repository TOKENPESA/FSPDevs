# MFA supervisor droplet — copy to .env before `docker compose -f docker-compose.mfa.yml up`.
# Generate tokens: openssl rand -hex 24

# --- Public site (nginx + CORS / WS origins) ---
# After TLS: PUBLIC_ORIGIN=https://mfa.example.com
PUBLIC_ORIGIN=http://YOUR_MFA_DROPLET_IP
MFA_WS_ALLOWED_ORIGINS=http://YOUR_MFA_DROPLET_IP,https://YOUR_MFA_DROPLET_IP,http://127.0.0.1:8088

# Allow remote laptop/desktop sidecars and the Treasury Hub droplet origin
# MFA_WS_ALLOWED_ORIGINS=https://mfa.example.com,http://127.0.0.1:8088

# --- MFA supervisor (release requires strong tokens) ---
MFA_BIND_ADDR=127.0.0.1:1025
MFA_API_TOKEN=REPLACE_MFA_API_TOKEN
MFA_AGENT_WS_TOKEN=REPLACE_MFA_WS_TOKEN
MFA_SUPERVISOR_DB_PATH=/app/data/mfa-supervisor.db
MFA_GRAPH_SNAPSHOT_PATH=/app/data/graph-snapshot.json
MFA_CLEARING_POLICY_PATH=/app/clearing-policy.yml
MESH_PUBKEY_REGISTRY_PATH=/app/mesh-pubkeys.json

# Point at the Treasury Hub Fiber/FNN RPC (nginx MFA-IP allowlist → loopback FNN)
HUB_RPC_URL=http://YOUR_TREASURY_DROPLET_IP:8227

# Testnet pilot: mock clearing until telco API is wired
MFA_TELCO_CLEARING_MOCK=1

# TLS: sudo bash deploy/droplet/setup-tls.sh mfa.example.com ops@example.com

# Phase B: edge rate limit defaults to SmartIp (X-Forwarded-For behind nginx).
# MFA_RATE_LIMIT_PEER_IP=1
