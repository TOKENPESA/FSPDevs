# Treasury Hub droplet — copy to .env before `docker compose -f docker-compose.treasury.yml up`.



# Hub agent identity (dedicated treasury FA, not a retail laptop sidecar)

AGENT_ID=1

FIBER_AGENT_BIND_ADDR=127.0.0.1:19444

# Required (≥16 chars) to call /api/modules/* — Bearer token, never query string.

FIBER_AGENT_API_TOKEN=REPLACE_WITH_OPENSSL_RAND_HEX_24



# MFA supervisor droplet (required — no local MFA on this host)

# Prefer hostname after TLS: MFA_HOST=mfa.example.com + MFA_WS_SECURE=true

MFA_HOST=YOUR_MFA_DROPLET_IP

MFA_AGENT_WS_TOKEN=REPLACE_MFA_WS_TOKEN

MFA_API_TOKEN=REPLACE_MFA_API_TOKEN

# MFA_WS_SECURE=true



# Optional live FNN on this droplet (otherwise leave unset / use simulated until FNN is installed)

# FNN_RPC_URL=http://127.0.0.1:18227

# FNN_MODE=simulate



MESH_PUBKEY_REGISTRY_PATH=/app/mesh-pubkeys.json

FIBER_AGENT_ALLOW_DEV_KEYS=false

