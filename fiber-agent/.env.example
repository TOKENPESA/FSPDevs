# Fiber Agent sidecar — production / testnet control-plane defaults
# Copy to `.env` for local overrides (`.env` is gitignored).
#
# Force TLS MFA endpoints (required for Android cleartext policy / App Transport Security).

FNN_MODE=testnet
# Local single-node FNN (fnn-testnet/start-testnet.ps1). Omit to use the default.
# FNN_RPC_URL=http://127.0.0.1:8227
MFA_HOST=mfa.fsprotocol.com
MFA_WS_SECURE=true

# Desktop default (when MFA_AGENT_WS_TOKEN unset): POST /api/register and persist FA-N secret.
# MFA_AUTO_REGISTER=true
# Legacy shared-token hub node (disables auto-register unless MFA_AUTO_REGISTER=true):
# AGENT_ID=1
# MFA_AGENT_WS_TOKEN=<from MFA MFA_AGENT_WS_TOKEN>

# --- Android (Tauri 2 / Kotlin+NDK) ---
# After installing Android Studio + NDK (Side by side), either:
#   . .\scripts\setup-android-env.ps1 -Persist -InstallRustTargets
# or set manually (Windows example):
#   ANDROID_HOME=%LOCALAPPDATA%\Android\Sdk
#   ANDROID_SDK_ROOT=%ANDROID_HOME%
#   NDK_HOME=%ANDROID_HOME%\ndk\<version>
#   ANDROID_NDK_HOME=%NDK_HOME%
#   JAVA_HOME=<Android Studio jbr path>
#
# Then:
#   npm run tauri:android:init
#   npm run tauri:android:build

# Optional local override examples:
# FNN_MODE=simulate
# MFA_HOST=127.0.0.1:1025
# MFA_WS_SECURE=false
# MFA_AUTO_REGISTER=false
# AGENT_ID=1
# MFA_AGENT_WS_TOKEN=your-shared-hub-token
