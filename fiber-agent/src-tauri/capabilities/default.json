{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the Fiber Agent desktop shell",
  "windows": ["main*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/fnn",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/fnn",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
